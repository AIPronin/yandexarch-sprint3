@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml



title "Тёплый дом. Диаграмма контекста для to-be решения"

Person(user, "Пользователь", "Пользователь системы Теплый дом")
System(warmhouse, "Тёплый дом", "Система управления устройствами в доме")

System_Ext(HeatingSystem, "Система управления отоплением", "Позволяет управлять отоплением в доме. Включает/выключает устройство, устанавливает требуемую температуру")
System_Ext(TemperatureSensor, "Датчики температуры", "Позволяет получить информацию о температуре в помещении")
System_Ext(LightSystem, "Система управления светом", "Позволяет включать и выключать свет")
System_Ext(Gate, "Система управления светом", "Позволяет запирать и отпирать автоматические ворота")
System_Ext(VideoSurveillanceSystem, "Система видеонаблюдения", "Позволяет удалённо наблюдать за домом")

Rel_D(user, warmhouse, "Регистрация и авторизация", "HTTPS")
Rel_D(user, warmhouse, "Добавление новых устройств", "HTTPS")
Rel_D(user, warmhouse, "Настройка сценариев работы устройств", "HTTPS")
Rel_D(user, warmhouse, "Управляет устройствами через приложение", "HTTPS")
Rel_D(user, warmhouse, "Получение данных с устройств", "HTTPS")
Rel_D(user, warmhouse, "Просмотр информации с камер видеонаблюдения", "HTTPS")

Rel_D(warmhouse, HeatingSystem, "Управление отоплением")
Rel_D(warmhouse, TemperatureSensor, "Получение температуры в помещении")
Rel_D(warmhouse, LightSystem, "Управление светом")
Rel_D(warmhouse, Gate, "Управление автоматическими воротами")
Rel_D(warmhouse, VideoSurveillanceSystem, "Просмотр данных с камер видеонаблюдения")


LAYOUT_WITH_LEGEND()
LAYOUT_TOP_DOWN()
@enduml